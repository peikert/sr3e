    "guide": {
      "actorbroadcaster": "<strong>Broadcaster</strong> — a news/signal source that feeds the scrolling news ticker; not a combatant.",
      "actorcharacter": "<strong>Character</strong> — a player or NPC character: attributes, skills, gear, magic, and vehicles.",
      "actorgmscreen": "<strong>Game Master Screen</strong> — a GM-only utility sheet for tracking every character's Karma and Dice Pools from one place.",
      "actormechanical": "<strong>Mechanical</strong> — a vehicle or drone, with handling, speed, armor, mounts, and its own condition monitor.",
      "actorstitle": "Actors",
      "buyingbuysuccess": "<span class=\"guide-action\">Shift+click</span> any die to buy one extra success by permanently burning 1 Karma Pool point. Works on every roll: on rolls with a target number you need at least one natural success already; open rolls (no target number) have no such requirement, so it's always available there.",
      "buyingintro": "Once a roll's dice appear in the chat message, you can spend Karma Pool on them:",
      "buyingreroll": "<span class=\"guide-action\">Click</span> any die to reroll. On target-number rolls this rerolls every currently-failed die at once. On simple/open rolls (no target number) <span class=\"guide-action\">right-click</span> the dice you want to reroll first to mark them, then click any die to reroll just the marked ones. Cost is 1 Karma the first time, 2 the second, and so on for the same test.",
      "buyingtitle": "Buying Successes & Rerolls",
      "firstlogintip": "<strong>Tip:</strong> Press <strong>F1</strong> to open the Guide for SR3E — dice rolls, buying successes, dice pools, and other system features.",
      "gadgetdescription": "A <strong>Gadget</strong> isn't used on its own — it's a modifier you attach to another item by dragging the Gadget onto that item's sheet (a weapon mod, armor plating, a spell fetish, a matrix program patch, vehicle add-on, and so on). Once attached it applies its bonuses as an Active Effect, with a switch on the host item to enable or disable it, and a button to detach it again.",
      "gadgettitle": "Gadgets",
      "itemadeptpower": "<strong>Adept Power</strong> — a Physical Adept's power, paid for with Power Points.",
      "itemammunition": "<strong>Ammunition</strong> — loaded into weapons; affects damage and armor penetration.",
      "itemaugmentation": "<strong>Augmentation</strong> — cyberware or bioware; costs Essence.",
      "itemcyberdeck": "<strong>Cyberdeck</strong> — a decker's deck; jack in to unlock the Hacking pool and the Matrix tab.",
      "itemfocus": "<strong>Focus</strong> — a bonded magical item that grants a Focus dice pool.",
      "itemgadget": "<strong>Gadget</strong> — see below.",
      "itemmagic": "<strong>Magic</strong> — a character's awakened tradition (Adept, Magician, etc.).",
      "itemmatrixprogram": "<strong>Matrix Program</strong> — software loaded onto a cyberdeck.",
      "itemmedical": "<strong>Medical</strong> — first aid kits, med-patches, and similar consumables.",
      "itemmetatype": "<strong>Metatype</strong> — the character's race (Human, Elf, Dwarf, Ork, Troll); sets attribute limits.",
      "itemskill": "<strong>Skill</strong> — the underlying definition backing a rollable skill entry.",
      "itemspell": "<strong>Spell</strong> — a spell in a magician's Grimoire.",
      "itemstitle": "Items",
      "itemtransaction": "<strong>Transaction</strong> — a nuyen entry (credstick, debt, or income) in the Rat's Race ledger.",
      "itemvehiclecontrolrig": "<strong>Vehicle Control Rig</strong> — lets a rigger jack into a vehicle to unlock the Control pool.",
      "itemweapon": "<strong>Weapon</strong> — firearms and melee weapons; carries damage, range, and ammo settings.",
      "itemwearable": "<strong>Wearable</strong> — armor and clothing; contributes Ballistic/Impact protection.",
      "riggerdeckercontrol": "The <strong>Control</strong> (rigging) pool appears once you're piloting a vehicle: open the Dossier's Garage tab, mark yourself <strong>Seated</strong> in the vehicle, then toggle <strong>Jacked In</strong> to its control rig.",
      "riggerdeckerhacking": "The <strong>Hacking</strong> pool only appears once a cyberdeck is active: open the Dossier's Matrix tab and toggle <strong>Jacked In</strong> on the deck you're using.",
      "riggerdeckertitle": "Dice Pools for Riggers & Deckers",
      "rollableattributes": "<strong>Attributes</strong> — Body, Quickness, Strength, Charisma, Intelligence, Willpower.",
      "rollableintro": "On a character sheet, click to roll:",
      "rollablepools": "<strong>Dice Pools</strong> — Combat, Control, Astral, Spell, and Hacking pools, plus a bonded Focus pool if the character has one.",
      "rollableskills": "<strong>Skills</strong> — Active, Knowledge, and Language skills and their specializations, in the Dossier's tab register.",
      "rollabletitle": "What's Rollable on the Sheet",
      "rollablevehicles": "<strong>Vehicles</strong> — mechanical/vehicle actions can be rolled from the Garage tab or the vehicle's own sheet.",
      "rollingadvanced": "<span class=\"guide-action\">Shift+click</span> a rollable field instead — or have a token targeted — to open the <strong>Roll Composer</strong> for an <strong>advanced roll</strong>. There you can allocate Dice Pool, bonded Focus, and Karma Pool dice, add situational modifiers, and confirm the target number before rolling.",
      "rollingsimple": "<span class=\"guide-action\">Click</span> any rollable field (an attribute, a skill, a dice pool) to roll it immediately with your current stats — a <strong>simple roll</strong>.",
      "rollingtitle": "Rolling Dice",
      "sheetcards": "<strong>Attributes, Dice Pools, Movement, Karma</strong> — core stat cards; click any value to roll it.",
      "sheetdossier": "<strong>Dossier</strong> — the tabbed register: Active/Knowledge/Language skills, Grimoire (if Awakened), Inventory, Garage, Matrix, Augmentations, Active Effects, and the Rat's Race (financial ledger).",
      "sheetdraghint": "Drag items from the sidebar, a compendium, or another actor onto the sheet to add gear.",
      "sheethealth": "<strong>Health</strong> — Stun and Physical damage tracks.",
      "sheetintro": "The character sheet is a grid of cards, each covering one part of the character:",
      "sheetprofile": "<strong>Profile</strong> — portrait, name, age/height/weight, and a personal quote.",
      "sheettitle": "The Character Sheet"
    },
